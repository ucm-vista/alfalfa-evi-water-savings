# Copy to .env and fill in. .env is git-ignored and must never be committed.

# OpenET API credentials (required only to (re)download ET via the OpenET API).
# Get a key at https://openet.dri.edu/  — ROTATE any previously shared key.
OPENET_API_KEY_1=your_openet_api_key_here
OPENET_API_KEY_2=optional_second_key_here

# Root that contains emery_method/, emery_method_2/, and shapefile/ (the data
# roots). Defaults to /home/jovyan/work if unset.
WORK_ROOT=/home/jovyan/work

# Optional: override the primary EVI time-series CSV path directly.
# EVI_CSV=/path/to/combined_evi_timeseries.csv
